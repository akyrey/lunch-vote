# ── Database ──────────────────────────────────────────────────────────────────
# Turso database URL (libSQL HTTP, e.g. libsql://your-db.turso.io)
TURSO_DATABASE_URL=

# Turso auth token (leave empty for local SQLite: file:./local.db)
TURSO_AUTH_TOKEN=

# ── Auth.js (NextAuth v5) ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth credentials (from console.cloud.google.com)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# App URL (used by Auth.js for callbacks)
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# ── Domain restriction ─────────────────────────────────────────────────────────
# Only email addresses from this domain are allowed to sign in
ALLOWED_EMAIL_DOMAIN=example.com

# Comma-separated list of admin email addresses (set isAdmin=true on first sign-in)
ADMIN_EMAILS=admin@example.com

# ── Cron security ─────────────────────────────────────────────────────────────
# Vercel sends this as Authorization: Bearer <token>  on cron requests
# Generate with: openssl rand -base64 32
CRON_SECRET=

# ── Office config ─────────────────────────────────────────────────────────────
# IANA timezone, e.g. Europe/Rome
OFFICE_TIMEZONE=Europe/Rome

# Poll open/close times in HH:MM (24h, in office timezone)
POLL_OPEN_TIME=11:30
POLL_CLOSE_TIME=12:30

# Currency symbol shown in the UI
CURRENCY=EUR

# ── Slack (deferred — set SLACK_ENABLED=true to activate) ────────────────────
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=
